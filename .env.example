# === Spindeln Configuration ===

# Orchestrator
SPINDELN_HOST=0.0.0.0
SPINDELN_PORT=8083
SPINDELN_LOG_LEVEL=INFO

# HiveMindDB
HIVEMINDDB_URL=http://hiveminddb:8100

# vLLM (local LLM — bulk extraction model)
VLLM_URL=http://vllm:8000/v1
VLLM_MODEL=Qwen/Qwen3.5-0.8B
VLLM_API_KEY=

# Synthesis model (optional — for fact validation + report generation)
# Leave empty to use the bulk model for everything
SYNTHESIS_API_URL=
SYNTHESIS_MODEL=
SYNTHESIS_API_KEY=

# SearXNG (metasearch)
SEARXNG_URL=http://searxng:8080

# Crawl4AI (web scraper)
CRAWL4AI_URL=http://crawl4ai:11235

# Loom (temporal data — read-only SQLite bridge, optional)
LOOM_DB_PATH=/data/loom/loom.db
LOOM_DATA_PATH=./data/loom

# === Optional API Keys ===

# Have I Been Pwned (free, rate-limited)
HIBP_API_KEY=

# Intelligence X (free tier)
INTELX_API_KEY=

# Hudson Rock Cavalier (free)
HUDSONROCK_API_KEY=

# Tor SOCKS5 Proxy
TOR_PROXY=socks5://tor-proxy:9050

# === Rate Limiting ===
SCRAPE_CONCURRENCY=5
SCRAPE_DELAY_SECONDS=2.0
SEARXNG_DELAY_SECONDS=1.0

# === Discovery Loop ===
MAX_DISCOVERY_ITERATIONS=5
